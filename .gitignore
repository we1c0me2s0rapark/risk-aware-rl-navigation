#==============================================================================
# @brief Git ignore configuration for CARLA-based perception and control project.
#
# Excludes build artefacts, Python environments, generated documentation,
# logs, and temporary files to maintain a clean repository state.
#==============================================================================


#==============================================================================
# Build / Compiled Files
#==============================================================================

## Object files
*.o
*.obj
*.lo
*.slo

## Static and dynamic libraries
*.a
*.lib
*.la
*.lai
*.so
*.dylib
*.dll

## Executables and binaries
*.exe
*.out
*.app

## Debugging and linker artefacts
*.pdb
*.ilk
*.dwo

## Precompiled headers
*.gch
*.pch

## Fortran module files (if applicable)
*.mod
*.smod


#==============================================================================
# Python Environment and Bytecode
#==============================================================================

## Virtual environments
.venv/

## Compiled Python bytecode
__pycache__/
*.pyc

## Jupyter Notebook checkpoints
.ipynb_checkpoints/


#==============================================================================
# Project Runtime Outputs
#==============================================================================

## Training runs, logs, and checkpoints
runs/
logs/
results/


#==============================================================================
# Documentation Outputs
#==============================================================================

## Doxygen configuration and generated HTML
Doxyfile
html/


#==============================================================================
# Temporary Files and Notes
#==============================================================================

tmp/